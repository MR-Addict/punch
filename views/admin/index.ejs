<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/images/favicon.png" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/admin/style.css" />
    <script src="/js/admin.js" defer></script>
    <title>值班笔记</title>
  </head>
  <body>
    <div class="container">
      <div class="container-body">
        <div class="icons">
          <button type="button" onclick="location.href = '/admin'" title="重置筛选结果">
            <img src="/images/reset.svg" alt="admin" />
            <p>重置</p>
          </button>
          <button type="button" onclick="location.href = '/insight'" title="统计所有结果">
            <img src="/images/insight.svg" alt="insight" />
            <p>统计</p>
          </button>
          <button type="button" onclick="location.href = '/export'" title="导出筛选结果">
            <img src="/images/export.svg" alt="export" />
            <p>导出</p>
          </button>
          <button type="button" onclick="location.href = '/'" title="返回提交页面">
            <img src="/images/home.svg" alt="home" />
            <p>首页</p>
          </button>
          <button type="button" onclick="location.href = '/logout'" title="退出当前登录">
            <img src="/images/logout.svg" alt="logout" />
            <p>退出</p>
          </button>
          <% if(login_user!=='admin'){ %>
          <button type="button" onclick="location.href = '/help'" title="查看帮助页面">
            <img src="/images/help.svg" alt="help" />
            <p>帮助</p>
          </button>
          <% }; %>
        </div>
        <h1>值班笔记查询</h1>
        <form class="search-box" action="/admin" method="post">
          <% if(login_user!=='admin'){ %>
          <div class="search">
            <button type="submit"><img src="/images/search.svg" alt="search" /></button>
            <input type="hidden" name="user" value="<%= login_user %>" />
            <input
              type="text"
              id="command"
              name="command"
              placeholder="输入SQL语句查询结果"
              maxlength="200"
              required
              oninvalid="this.setCustomValidity('SQL语句不能为空！')"
              oninput="this.setCustomValidity('')"
              list="commands-options"
            />
            <datalist id="commands-options">
              <% if( login_user === 'punch_sc' ) { %>
              <option value="SELECT `id`,`date`,`notes` FROM `punch`"></option>
              <% } else { %>
              <option value="SELECT `id`,`group`,`date`,`notes` FROM `punch`"></option>
              <!-- different department group -->
              <% if( login_user === 'punch_js' ) { %>
              <option value="SELECT * FROM `punch` WHERE `group` = '航模组'"></option>
              <% } else if( login_user === 'punch_zc' ) { %>
              <option value="SELECT * FROM `punch` WHERE `group` = 'PU组'"></option>
              <% } else if( login_user === 'punch_kp' ) { %>
              <option value="SELECT * FROM `punch` WHERE `group` = '策划组'"></option>
              <% } else if( login_user === 'punch_xx' ) { %>
              <option value="SELECT * FROM `punch` WHERE `group` = '微信推送组'"></option>
              <% } else if( login_user === 'punch_wl' ) { %>
              <option value="SELECT * FROM `punch` WHERE `group` = '校内组'"></option>
              <% } %>
              <!-- end -->
              <% } %>
              <option value="SELECT * FROM `punch` WHERE LENGTH(`notes`) > 100"></option>
              <option value="SELECT * FROM `punch` WHERE DATE(`date`) > '2022-8-13'"></option>
              <option value="SELECT * FROM `punch` WHERE DATE(`date`) = CURRENT_DATE"></option>
              <option value="SELECT * FROM `punch` WHERE WEEK(`date`,1) = WEEK(CURRENT_DATE(),1)"></option>
              <option value="SELECT *, LENGTH(`notes`) as '字数' FROM `punch` WHERE `name` = 'Cael'"></option>
              <option
                value="SELECT `date` AS '日期', COUNT(*) AS '提交次数' FROM `punch` GROUP BY DATE(`date`)"
              ></option>
            </datalist>
          </div>
          <% }; %>
        </form>
        <div class="status">
          <div class="sta-left">
            <div class="sta-element">当前结果:<span id="sta-current-records"></span></div>
            <div class="sta-element">所有结果:<span id="sta-all-records"></span></div>
            <div class="sta-element">当前页数:<span id="sta-current-page"></span>/<span id="sta-all-pages"></span></div>
          </div>
          <div class="sta-right">
            <% if(login_user==='admin'){ %>
            <p class="sta-element">部门</p>
            <select id="department_select" name="department_select" class="sta-element">
              <option value="0">技术开发部</option>
              <option value="1">组织策划部</option>
              <option value="2">科普活动部</option>
              <option value="3">新闻宣传部</option>
              <option value="4">对外联络部</option>
              <option value="5">双创联合服务部</option>
            </select>
            <% }; %>
            <p class="sta-element">每页数目</p>
            <select id="records_per_page" name="records_per_page" class="sta-element">
              <option value="10">10</option>
              <option value="20">20</option>
              <option value="50" selected>50</option>
              <option value="100">100</option>
            </select>
          </div>
        </div>
        <div class="records-list">
          <!-- Admin pages -->
          <% records.forEach(function(department) { %>
          <table class="multi-page-table">
            <thead>
              <!-- Title -->
              <tr>
                <% Object.keys(department[0]).forEach(function(prop) { %>
                <th><%= prop %></th>
                <% }); %>
                <!-- Title End -->
              </tr>
            </thead>
            <!-- Content -->
            <tbody>
              <!-- department -->
              <% department.forEach(function(record){ %>
              <tr>
                <% Object.keys(record).forEach(function(prop) { %>
                <td><%= record[prop]; %></td>
                <% }); %>
              </tr>
              <!-- department end -->
              <% }); %>
            </tbody>
            <!-- Content End -->
          </table>
          <!-- Admin end -->
          <% }); %>
        </div>
        <div id="table-pages-nav-buttons"></div>
      </div>
      <footer class="footer">&copy; Copyright <%= new Date().getFullYear() %> 校大学生科协</footer>
    </div>
  </body>
</html>
